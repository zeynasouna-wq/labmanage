# LaboStock Environment Variables
# Copy this file to .env and fill in the values

# ==================== ENVIRONMENT MODE ====================
# Set to "local" for development or "production" for production
# This controls debug mode, CORS settings, and other features
ENVIRONMENT=local

# ==================== DATABASE CONFIGURATION ====================
# For LOCAL development (SQLite):
DATABASE_URL=sqlite:///./labo_stock.db

# For RENDER/PRODUCTION (PostgreSQL):
# DATABASE_URL will be automatically set by Render from the database service
# Uncomment and modify for local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/labmanage

# ==================== FASTAPI CONFIGURATION ====================
APP_NAME=LaboStock
APP_VERSION=1.0.0

# ==================== SECURITY ====================
SECRET_KEY=your-super-secret-key-min-32-characters-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== CORS CONFIGURATION ====================
# Comma-separated allowed origins
# For LOCAL development:
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# For PRODUCTION:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ==================== API SERVER ====================
API_HOST=127.0.0.1
API_PORT=8000

# ==================== INITIAL ADMIN USER ====================
FIRST_ADMIN_EMAIL=admin@labo.sn
FIRST_ADMIN_PASSWORD=Admin@2024!
FIRST_ADMIN_NAME=Administrateur

# ==================== ALERT CONFIGURATION ====================
ALERT_CHECK_INTERVAL_HOURS=24
EXPIRY_ALERT_DAYS_BEFORE=30
